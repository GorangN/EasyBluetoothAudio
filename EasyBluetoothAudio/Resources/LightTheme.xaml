<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

   <!-- ═══════════════════════════════════════════════════════════
        LIGHT THEME COLOR DEFINITIONS - CLEAN MODERN
        Clean neutral background, floating white cards, minimal borders.
        ═══════════════════════════════════════════════════════════ -->

   <!-- Accents -->
   <Color x:Key="AcidYellowColor">#B8A000</Color>  <!-- Softer gold — used sparingly as accent only -->
   <Color x:Key="NeonCyanColor">#006B75</Color>
   <Color x:Key="NeonGreenColor">#2E7D32</Color>
   <Color x:Key="NeonRedColor">#C62828</Color>

   <!-- Backgrounds & Surfaces (Modern Clean — 3-layer depth) -->
   <Color x:Key="DeepBlackColor">#F5F3E2</Color>   <!-- App Window Background (very light yellow tint) -->
   <Color x:Key="BackgroundColor">#EEEbD5</Color>  <!-- Scroller Background -->
   <Color x:Key="SurfaceColor">#FFFFFF</Color>      <!-- Cards (float above background) -->
   <Color x:Key="SectionBorderColor">#E8E8EE</Color> <!-- Subtle border -->

   <!-- Typography & Icons -->
   <Color x:Key="TextWhiteColor">#1A1A1A</Color>
   <Color x:Key="LightGreyColor">#6B6B80</Color>   <!-- Secondary text (cool gray) -->
   <Color x:Key="DarkerGreyColor">#BEBEC8</Color>  <!-- Borders / Dividers -->

   <!-- Diagonal Stripe (barely visible on this background) -->
   <Color x:Key="DiagonalStripeColor">#07000000</Color>

   <SolidColorBrush x:Key="AcidYellowBrush" Color="{StaticResource AcidYellowColor}"/>
   <SolidColorBrush x:Key="DeepBlackBrush"  Color="{StaticResource DeepBlackColor}"/>
   <SolidColorBrush x:Key="LightGreyBrush"  Color="{StaticResource LightGreyColor}"/>
   <SolidColorBrush x:Key="DarkerGreyBrush" Color="{StaticResource DarkerGreyColor}"/>
   <SolidColorBrush x:Key="TextWhiteBrush"  Color="{StaticResource TextWhiteColor}"/>
   <SolidColorBrush x:Key="NeonCyanBrush"   Color="{StaticResource NeonCyanColor}"/>
   <SolidColorBrush x:Key="NeonGreenBrush"  Color="{StaticResource NeonGreenColor}"/>
   <SolidColorBrush x:Key="NeonRedBrush"    Color="{StaticResource NeonRedColor}"/>
   <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
   <SolidColorBrush x:Key="SurfaceBrush"    Color="{StaticResource SurfaceColor}"/>
   <SolidColorBrush x:Key="SectionBorderBrush" Color="{StaticResource SectionBorderColor}"/>
   <SolidColorBrush x:Key="DiagonalStripeColorBrush" Color="{StaticResource DiagonalStripeColor}"/>

   <!-- ═══════════════════════════════════════════════════════════
        SEMANTIC BRUSHES (LIGHT THEME)
        ═══════════════════════════════════════════════════════════ -->
   <SolidColorBrush x:Key="PrimaryActionBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
   <SolidColorBrush x:Key="PrimaryActionForegroundBrush" Color="#1A1A1A"/>
   <SolidColorBrush x:Key="PrimaryActionBorderBrush"     Color="{StaticResource AcidYellowColor}"/>
   <SolidColorBrush x:Key="PrimaryActionHoverBrush"      Color="#F5F5F8"/>

   <SolidColorBrush x:Key="ActionBackgroundBrush"        Color="#1A1A1A"/>
   <SolidColorBrush x:Key="ActionForegroundBrush"        Color="White"/>
   <SolidColorBrush x:Key="ActionHoverBrush"             Color="#3D3D3D"/>
   <SolidColorBrush x:Key="StatusOverlayBrush"           Color="#08000000"/>

   <!-- Settings Specific Brushes -->
   <SolidColorBrush x:Key="SettingsControlBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
   <SolidColorBrush x:Key="SettingsControlForegroundBrush" Color="#1A1A1A"/>
   <SolidColorBrush x:Key="SettingsControlBorderBrush"     Color="{StaticResource SectionBorderColor}"/>
   <SolidColorBrush x:Key="SecondaryActionHoverBrush"      Color="#F0F0F5"/>

</ResourceDictionary>
